# ============================================================
#  PneumoDetectAI Backend – Environment Variables Template
# ============================================================
#
#  Copy this file to `.env` in the backend/ directory:
#    cp .env.example .env
#
#  Values in .env override the defaults in app/core/config.py.
#  Never commit .env to version control!
# ============================================================

# --- Server ---
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=info

# --- CORS ---
# Comma-separated list of allowed origins.
# Add your production frontend URL here when deploying.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# --- Model ---
# Uncomment and set this to point directly at your .h5 file.
# If empty, the loader will try the paths in model_search_paths.
# MODEL_PATH_OVERRIDE=/absolute/path/to/best_chest_xray_model.h5

# --- Data paths (override if your layout differs) ---
# DATA_ROOT=/absolute/path/to/data
# PROCESSED_DATA_DIR=/absolute/path/to/data/processed
# MODELS_DIR=/absolute/path/to/models
# RESULTS_DIR=/absolute/path/to/results

# --- Training hyper-parameters ---
# TRAIN_IMG_SIZE=224
# TRAIN_BATCH_SIZE=32
# TRAIN_EPOCHS=25
# TRAIN_LEARNING_RATE=0.001
